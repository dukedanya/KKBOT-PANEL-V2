BOT_TOKEN=
ADMIN_USER_IDS=

APP_ENV=production
LOG_LEVEL=INFO

DATABASE_URL=postgresql://kkbot:kkbot@127.0.0.1:5432/kkbot
DATABASE_MIN_POOL=1
DATABASE_MAX_POOL=10

LEGACY_SQLITE_PATH=
AUTO_MIGRATE_LEGACY=true
LEGACY_IMPORT_BATCH_SIZE=1000

PANEL_BASE=https://kakoivpn.ru:8443/A8GGbEuizKONIMbY3e/
SUB_PANEL_BASE=https://kakoivpn.ru:8443/panel-sub/
PANEL_LOGIN=
PANEL_PASSWORD=
VERIFY_SSL=true

WEBHOOK_ENABLED=false
WEBHOOK_HOST=
WEBHOOK_PORT=8080
MERGED_SUBSCRIPTION_API_BASE=https://connect.kakoivpn.ru:8443
MERGED_SUBSCRIPTION_FORMAT=plain
MERGED_SUBSCRIPTION_INCLUDE_BASE_URL=true

# Legacy V1-compatible runtime also reads this root .env through src/config.py.
HAPP_SUBSCRIPTION_API_BASE=https://connect.kakoivpn.ru:8443

CIDR_OBJECT_STORAGE_SYNC_ENABLED=true
CIDR_OBJECT_STORAGE_SYNC_INTERVAL_SEC=3600
CIDR_OBJECT_STORAGE_SOURCE_URLS=https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/refs/heads/main/Vless-Reality-White-Lists-Rus-Mobile.txt,https://github.com/FLEXIY0/matryoshka-vpn/raw/main/configs/russia_whitelist.txt
CIDR_OBJECT_STORAGE_LOCAL_PATH=/root/kkvpnbot/data/cidr-config.txt
LTE_OBJECT_STORAGE_BUCKET=connect.kakoivpn.ru
LTE_OBJECT_STORAGE_ACCESS_KEY_ID=
LTE_OBJECT_STORAGE_SECRET_ACCESS_KEY=
LTE_OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net
LTE_OBJECT_STORAGE_OBJECT_NAME=config.txt
LTE_OBJECT_STORAGE_PUBLIC_READ=true
