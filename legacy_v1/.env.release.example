ENVIRONMENT=production
DEBUG=false
RELEASE_PROFILE_ENFORCED=true

APP_MODE=polling
LOG_LEVEL=INFO
LOG_JSON=true
LOG_TO_FILE=true
VERIFY_SSL=true

MIGRATIONS_AUTO_APPLY=true
STARTUP_FAIL_ON_PENDING_MIGRATIONS=true
STARTUP_FAIL_ON_SCHEMA_DRIFT=true
STARTUP_RECOVER_STALE_PROCESSING=true

ENABLE_HEALTH_ENDPOINTS=true
HEALTHCHECK_PATH=/healthz
READINESS_PATH=/readyz

PANEL_BASE=https://panel.example.com/A8GGbEuizKONIMbY3e/
PANEL_LOGIN=admin
PANEL_PASSWORD=secret
SUB_PANEL_BASE=https://panel.example.com/sub/
MERGED_SUBSCRIPTION_API_BASE=http://127.0.0.1:8787
MERGED_SUBSCRIPTION_FORMAT=base64
MERGED_SUBSCRIPTION_INCLUDE_BASE_URL=true
LTE_REPORT_API_HEALTH_URL=http://127.0.0.1:8787/health
TOTAL_TRAFFIC_STATE_PATH=/root/lte-whitelist/server/data/total-traffic-state.json
TOTAL_TRAFFIC_STATE_URL=
GRACE_STATE_PATH=/root/lte-whitelist/server/data/grace-state.json
TOTAL_TRAFFIC_STATE_MAX_AGE_SEC=1800
ENABLE_SERVER_BOOTSTRAP=false
SERVER_BOOTSTRAP_SOURCE_ROOT=
SERVER_BOOTSTRAP_REMOTE_ROOT=/root/lte-whitelist
SERVER_BOOTSTRAP_SSH_HOST=
SERVER_BOOTSTRAP_SSH_PORT=22
SERVER_BOOTSTRAP_SSH_USER=root
SERVER_BOOTSTRAP_SSH_PASSWORD=
SERVER_BOOTSTRAP_INSTALL_SYSTEMD=true
PANEL_TARGET_INBOUND_IDS=1,2,3,4,5,6,7
PANEL_TARGET_INBOUND_COUNT=0
PANEL_EMAIL_DOMAIN=kakoitovpn
PANEL_EMAIL_PREFIX=
ITPAY_PUBLIC_BASE_FALLBACK=http://127.0.0.1

PAYMENT_CREATE_COOLDOWN_SEC=10
MAX_PENDING_PAYMENTS_PER_USER=3
PAYMENT_ACTIVATION_RETRY_BASE_SEC=60
PAYMENT_ACTIVATION_RETRY_MAX_SEC=1800
PAYMENT_ACTIVATION_MAX_ATTEMPTS=5

START_COMMAND_DEDUP_WINDOW_SEC=2.0
COMMAND_RATE_LIMIT_SEC=0.8
CALLBACK_RATE_LIMIT_SEC=0.35
CALLBACK_DEDUP_WINDOW_SEC=1.5
ERROR_ALERT_COOLDOWN_SEC=120

BACKUP_DIR=/data/backups
BACKUP_KEEP=14
